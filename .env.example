# Supabase — https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# TMDb (The Movie Database) — https://www.themoviedb.org/settings/api
# Utilisez le "API Read Access Token" (Bearer token)
# Option A : token en clair (développement)
TMDB_API_READ_ACCESS_TOKEN=<your-tmdb-read-access-token>

# Chiffrement AES-256-GCM du token TMDb stocké en base
# Générer avec : openssl rand -hex 32
# Requis en production si TMDB_API_READ_ACCESS_TOKEN n'est pas défini
ENCRYPTION_KEY=<64-char-hex-string>
